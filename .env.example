# Copy this file to .env and replace every example value before deployment.

SERVER_NAME=example.com
MATRIX_HOST=matrix.example.com
CHAT_HOST=chat.example.com

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=replace-with-a-long-random-password

SYNAPSE_TAG=v1.155.0
# SelfMatrix fork image. Update this reviewed sha tag deliberately when promoting a new web client.
CINNY_IMAGE=ghcr.io/zoobookfool/selfmatrix-cinny
CINNY_TAG=sha-4197034
SYNAPSE_REPORT_STATS=no
TZ=Asia/Tokyo
# Optional: Synapse upload cap (default 90M — kept inside Cloudflare's free-plan 100MB limit)
MAX_UPLOAD_SIZE=90M
# Optional: how many backup generations scripts/backup.sh keeps (default 7)
BACKUP_KEEP=7

# Moderation dashboard (synapse-admin). Off by default; start with
# `docker compose --profile admin up -d synapse-admin`. Do NOT expose this
# port to the internet -- keep it on a private interface (Tailscale IP,
# localhost, or an SSH tunnel). See docs/operations.md.
# SYNAPSE_ADMIN_BIND must be in IP:PORT form. A bare port ("8083") would
# silently bind to 0.0.0.0 and expose the dashboard on every interface.
SYNAPSE_ADMIN_TAG=0.11.4
SYNAPSE_ADMIN_BIND=127.0.0.1:8083

# Invite-code registration. When true, generate-synapse-config.sh sets
# enable_registration: true + registration_requires_token: true in
# homeserver.yaml -- registration stays closed to anyone without a token
# issued via scripts/invite-token.sh. Re-run generate-synapse-config.sh
# --force and restart Synapse after changing this.
ENABLE_INVITE_REGISTRATION=false

# When true, the login/register screen also offers a "custom homeserver"
# option so people with an existing account on ANY other homeserver (e.g.
# matrix.org) can log in through this same client -- no account is created on
# this server. The default homeserver (SERVER_NAME above) stays the
# pre-selected option either way; this only adds a second choice. Re-run
# generate-cinny-config.sh after changing this.
ALLOW_CUSTOM_HOMESERVERS=false
